{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/normalized-lead.schema.json",
  "title": "NormalizedLead",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lead_id",
    "source",
    "received_at",
    "contact",
    "content",
    "metadata",
    "raw_input"
  ],
  "properties": {
    "lead_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": ["website_form", "facebook_ad", "missed_call_transcript"]
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": ["string", "null"]
        },
        "email": {
          "type": ["string", "null"],
          "format": "email"
        },
        "phone": {
          "type": ["string", "null"]
        },
        "company": {
          "type": ["string", "null"]
        }
      },
      "anyOf": [
        {
          "required": ["email"],
          "properties": {
            "email": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "required": ["phone"],
          "properties": {
            "phone": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "message": {
          "type": ["string", "null"]
        },
        "transcript": {
          "type": ["string", "null"]
        }
      },
      "anyOf": [
        {
          "required": ["message"],
          "properties": {
            "message": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "required": ["transcript"],
          "properties": {
            "transcript": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaign", "language", "external_id"],
      "properties": {
        "campaign": {
          "type": ["string", "null"]
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "external_id": {
          "type": ["string", "null"]
        }
      }
    },
    "raw_input": {
      "type": "object"
    }
  }
}
